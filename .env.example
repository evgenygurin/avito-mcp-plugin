# Пример переменных окружения. Скопируйте в .env и заполните.
# .env игнорируется git — НЕ коммитьте реальные секреты.

# --- Куки (провайдер выбирается AVITO_COOKIE_PROVIDER) ---
# Провайдер кук: spfa | own | playwright (дефолт spfa)
AVITO_COOKIE_PROVIDER=spfa
# Ключ spfa.ru (POST /api/cookies + /unblock) — нужен для провайдера spfa
SPFA_API_KEY=
# Готовые куки пользователя — нужны только для провайдера own
AVITO_OWN_COOKIES=

# --- Прокси (ротация до чистого IP) ---
# Формат user:pass@host:port. Можно список через запятую — тогда при блокировке
# перебираются адреса пула (ProxyPool), а не один выжженный IP
AVITO_PROXY=
# URL смены IP (мобильный прокси) — опционально, включает ротацию
AVITO_PROXY_CHANGE_URL=
# URL кабинета со списком прокси (JSON-массив или по адресу на строку).
# Задан — список берётся оттуда; недоступен — падаем на AVITO_PROXY
AVITO_PROXY_LIST_URL=
# Лимит попыток ротации IP до чистого (дефолт 5). Backoff min(9*2^n, 60) с:
# 5 попыток = до 123 с ожидания, 18 = 903 с (тулза упиралась в свой timeout)
AVITO_MAX_ROTATE_ATTEMPTS=5

# --- Эскалация прокси (API mobileproxy.space, опционально) ---
# Простая ротация IP (AVITO_PROXY_CHANGE_URL) меняет адрес в пределах той же
# подсети — не спасает, если Qrator забанил всю подсеть региона/оператора
# целиком. Если заданы оба параметра ниже, HttpClient при исчерпании обычной
# ротации САМ переключает физическую точку на не-московскую через API
# mobileproxy.space (mpsapi.com) и повторяет попытку — без ручных действий
# в личном кабинете. Bearer-токен: mobileproxy.space → личный кабинет → API
AVITO_MPS_API_TOKEN=
# ID прокси в кабинете (mpsapi.com: command=get_my_proxy)
AVITO_PROXY_ID=
# Оператор, на который переключаться при эскалации (дефолт megafone)
AVITO_MPS_OPERATOR=megafone
# Пауза между страницами каталога, сек (дефолт 1.0) — без неё многостраничный
# обход выжигает IP быстрее, чем успевает собрать данные
AVITO_PAGE_PAUSE=1.0

# Где хранить купленные куки между вызовами (дефолт ~/.cache/avito-mcp-server/cookies.json).
# Куки spfa живут ~12 ч и стоят денег — без кэша каждый вызов тулзы покупает новые
AVITO_COOKIES_CACHE=

# --- Уведомления ---
# Telegram-бот: токен и chat_id через запятую
AVITO_TG_TOKEN=
AVITO_TG_CHAT_IDS=
# VK: токен и user_id через запятую
AVITO_VK_TOKEN=
AVITO_VK_USER_IDS=

# --- Хранилище: Postgres проекта Supabase (dedup + история цены + cooldown) ---
# DSN: Project Settings → Database → Connection string (URI).
# Схема avito, доступ по service_role. Без него мониторинг и история не работают
AVITO_SUPABASE_DSN=

# --- MCP-сервер ---
# Уровень логирования: debug | info | warning | error (пока не читается сервером)
LOG_LEVEL=info

# Каталог skills/ для раздачи по MCP (опционально).
# По умолчанию берётся ${CLAUDE_PLUGIN_ROOT}/skills или каталог репозитория.
# AVITO_SKILLS_DIR=/path/to/avito-mcp-plugin/skills
