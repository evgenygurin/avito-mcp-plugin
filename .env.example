# Пример переменных окружения. Скопируйте в .env и заполните.
# .env игнорируется git — НЕ коммитьте реальные секреты.

# --- Куки (провайдер выбирается AVITO_COOKIE_PROVIDER) ---
# Провайдер кук: spfa | own | playwright (дефолт spfa)
AVITO_COOKIE_PROVIDER=spfa
# Ключ spfa.ru (POST /api/cookies + /unblock) — нужен для провайдера spfa
SPFA_API_KEY=
# Готовые куки пользователя — нужны только для провайдера own
AVITO_OWN_COOKIES=

# --- Прокси (ротация до чистого IP) ---
# Формат user:pass@host:port
AVITO_PROXY=
# URL смены IP (мобильный прокси) — опционально, включает ротацию
AVITO_PROXY_CHANGE_URL=
# Лимит попыток ротации IP до чистого (дефолт 18)
AVITO_MAX_ROTATE_ATTEMPTS=18

# --- Уведомления ---
# Telegram-бот: токен и chat_id через запятую
AVITO_TG_TOKEN=
AVITO_TG_CHAT_IDS=
# VK: токен и user_id через запятую
AVITO_VK_TOKEN=
AVITO_VK_USER_IDS=

# --- Хранилище (dedup + история цены) ---
# Путь к sqlite-файлу
AVITO_DB_PATH=

# --- MCP-сервер ---
# Уровень логирования: debug | info | warning | error (пока не читается сервером)
LOG_LEVEL=info

# Каталог skills/ для раздачи по MCP (опционально).
# По умолчанию берётся ${CLAUDE_PLUGIN_ROOT}/skills или каталог репозитория.
# AVITO_SKILLS_DIR=/path/to/avito-mcp-plugin/skills
